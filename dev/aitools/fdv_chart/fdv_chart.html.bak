<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>FDV Chart Parser</title>
    <style>
        * { box-sizing: border-box; }
        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
            font-family: Arial, sans-serif;
            display: flex;
            flex-direction: column;
        }

        /* ── TOP CONTROL PANEL ── */
        #top-panel {
            flex: 0 0 auto;
            padding: 10px 16px 6px 16px;
            background: #f8f9fa;
            border-bottom: 2px solid #dee2e6;
        }
        #top-panel h1 {
            margin: 0 0 6px 0;
            font-size: 1.2em;
            color: #333;
        }
        .ctrl-row {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 5px;
        }
        .ctrl-label {
            font-size: 0.82em;
            color: #555;
            white-space: nowrap;
        }
        #file-input { font-size: 0.9em; }
        #regex-input {
            flex: 1 1 300px;
            padding: 5px 8px;
            font-family: monospace;
            font-size: 0.9em;
            border: 1px solid #ccc;
            border-radius: 4px;
            min-width: 200px;
        }
        .radio-group { display: flex; gap: 12px; font-size: 0.88em; }
        .btn {
            padding: 6px 16px;
            background: #007bff;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 0.9em;
            white-space: nowrap;
        }
        .btn:hover { background: #0056b3; }
        .btn.sec { background: #6c757d; }
        .btn.sec:hover { background: #545b62; }
        .btn.grn { background: #28a745; }
        .btn.grn:hover { background: #1e7e34; }

        /* ── STATUS BAR ── */
        #status-bar {
            font-size: 0.82em;
            padding: 3px 0;
            min-height: 22px;
            color: #155724;
        }
        #status-bar.error { color: #721c24; }
        #status-bar.info  { color: #0c5460; }

        /* ── BOTTOM TABLE PANEL ── */
        #bottom-panel {
            flex: 1 1 0;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            background: #fff;
        }
        #table-bar {
            flex: 0 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 4px 12px;
            background: #e9ecef;
            border-bottom: 1px solid #ced4da;
            font-size: 0.82em;
            color: #495057;
            min-height: 28px;
        }
        #table-container {
            flex: 1 1 0;
            overflow: auto;
        }
        #result-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.82em;
        }
        #result-table thead th {
            background: #343a40;
            color: #fff;
            padding: 6px 8px;
            text-align: left;
            position: sticky;
            top: 0;
            white-space: nowrap;
            z-index: 1;
        }
        #result-table tbody td {
            padding: 4px 8px;
            border-bottom: 1px solid #e9ecef;
            white-space: nowrap;
        }
        #result-table tbody tr:hover { background: #fff3cd; }
        #result-table tbody tr:nth-child(even) { background: #f8f9fa; }
        #result-table tbody tr:nth-child(even):hover { background: #fff3cd; }

        #empty-state {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100%;
            color: #aaa;
            font-size: 1.1em;
        }

        /* ── PLOT PANEL ── */
        #plot-panel {
            flex: 0 0 auto;
            display: none;
            flex-direction: column;
            border-bottom: 2px solid #dee2e6;
            background: #fff;
            min-height: 60px;
        }
        #plot-bar {
            flex: 0 0 auto;
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
            padding: 5px 12px;
            background: #e9ecef;
            border-bottom: 1px solid #ced4da;
            font-size: 0.82em;
        }
        #plot-bar select, #plot-bar input[type=text] {
            padding: 3px 6px;
            font-size: 0.88em;
            border: 1px solid #ccc;
            border-radius: 3px;
        }
        #plot-bar label { white-space: nowrap; color: #555; }
        #plot-area {
            flex: 1 1 0;
            position: relative;
            min-height: 220px;
            max-height: 340px;
        }
        #plot-area canvas { position: absolute; top:0; left:0; width:100%; height:100%; }

        /* ── FILTER ROW ── */
        #filter-row th {
            background: #495057;
            padding: 3px 4px;
            position: sticky;
            top: 33px;   /* below header row */
            z-index: 1;
        }
        #filter-row th input {
            width: 100%;
            padding: 2px 4px;
            font-size: 0.78em;
            border: 1px solid #adb5bd;
            border-radius: 2px;
            background: #fff;
            box-sizing: border-box;
            min-width: 40px;
        }
        #filter-row th input.active  { border-color: #ffc107; background: #fff9e6; }
        #filter-row th input.invalid { border-color: #dc3545; background: #fff0f0; }
        #filter-row th input.op      { border-color: #17a2b8; background: #e8f7fb; }
        .row-hidden { display: none; }

        /* ── DRAG HANDLE ── */
        #drag-handle {
            flex: 0 0 6px;
            cursor: ns-resize;
            background: #dee2e6;
            border-top: 1px solid #ced4da;
            border-bottom: 1px solid #ced4da;
        }
        #drag-handle:hover { background: #adb5bd; }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
</head>
<body>

<!-- ═══════════════ TOP PANEL ═══════════════ -->
<div id="top-panel">
    <h1>&#128202; FDV Chart Parser</h1>
    <div class="ctrl-row">
        <span class="ctrl-label">File&nbsp;path:</span>
        <input type="text" id="path-input" placeholder="e.g. D:\FDV\logs\A1\PLC\Output_site114_4_01_2026_20_01_45.txt" style="flex:2 1 400px;min-width:200px">

        <span class="ctrl-label">or&nbsp;upload:</span>
        <input type="file" id="file-input" accept=".txt,.log,.csv">

        <span class="ctrl-label">Regex:</span>
        <input type="text" id="regex-input" placeholder="optional — e.g. ^FDV POLL or ^FDV OUTPUT" style="flex:1 1 260px">

        <span class="ctrl-label">Mode:</span>
        <div class="radio-group">
            <label><input type="radio" name="filter-mode" value="include" checked> Include</label>
            <label><input type="radio" name="filter-mode" value="exclude"> Exclude</label>
        </div>

        <button class="btn" onclick="parseFile()">&#9654; Parse</button>
        <button class="btn sec" onclick="resetAll()">&#10006; Clear</button>
        <button class="btn grn" id="download-btn" onclick="downloadCSV()" style="display:none">&#8595; CSV</button>
    </div>
    <div id="status-bar">Ready — select a file and click Parse.</div>
</div>

<!-- ═══════════════ PLOT PANEL ═══════════════ -->
<div id="plot-panel">
    <div id="plot-bar">
        <label>X:
            <select id="x-col"></select>
        </label>
        <label style="margin-left:4px">X&nbsp;regex:
            <input type="text" id="x-regex" placeholder="e.g. ([0-9]+)" style="width:110px">
        </label>
        <label style="margin-left:8px">Y:
            <select id="y-col"></select>
        </label>
        <label style="margin-left:4px">Y&nbsp;regex:
            <input type="text" id="y-regex" placeholder="e.g. ([0-9]+)" style="width:110px">
        </label>
        <label style="margin-left:8px">Color&nbsp;by:
            <select id="color-col"><option value="">— none —</option></select>
        </label>
        <label id="color-rx-label" style="margin-left:4px">Color&nbsp;regex:
            <input type="text" id="color-regex" placeholder="e.g. DUT(\d+)" style="width:110px">
        </label>
        <label style="margin-left:8px">Type:
            <select id="chart-type" onchange="onChartTypeChange()">
                <option value="scatter">Scatter</option>
                <option value="line">Line</option>
                <option value="histogram">Histogram</option>
                <option value="cumproba">Cum Proba</option>
            </select>
        </label>
        <label id="bins-label" style="margin-left:4px;display:none">Bins:
            <input type="number" id="hist-bins" value="" min="2" max="500" placeholder="auto" style="width:60px">
        </label>
        <label id="split-label" style="margin-left:8px;display:none">Split&nbsp;by:
            <select id="split-col"><option value="">— none —</option></select>
        </label>
        <label id="split-rx-label" style="margin-left:4px;display:none">Split&nbsp;regex:
            <input type="text" id="split-regex" placeholder="e.g. DUT(\d+)" style="width:110px">
        </label>
        <button class="btn" style="padding:4px 12px" onclick="drawPlot()">&#9654; Plot</button>
        <label style="margin-left:8px;font-size:0.82em;color:#555">
            <input type="checkbox" id="x-log"> X&nbsp;log
        </label>
        <label style="margin-left:4px;font-size:0.82em;color:#555">
            <input type="checkbox" id="y-log"> Y&nbsp;log
        </label>
        <label id="x-min-label" style="margin-left:8px;font-size:0.82em;color:#555">X&nbsp;min:
            <input type="number" id="x-min" placeholder="auto" style="width:70px;font-size:0.9em">
        </label>
        <label id="x-max-label" style="margin-left:2px;font-size:0.82em;color:#555">max:
            <input type="number" id="x-max" placeholder="auto" style="width:70px;font-size:0.9em">
        </label>
        <label id="y-min-label" style="margin-left:8px;font-size:0.82em;color:#555">Y&nbsp;min:
            <input type="number" id="y-min" placeholder="auto" style="width:70px;font-size:0.9em">
        </label>
        <label id="y-max-label" style="margin-left:2px;font-size:0.82em;color:#555">max:
            <input type="number" id="y-max" placeholder="auto" style="width:70px;font-size:0.9em">
        </label>
        <span id="plot-status" style="color:#555;font-size:0.85em;margin-left:6px"></span>
    </div>
    <div id="plot-area">
        <canvas id="plot-canvas"></canvas>
    </div>
    <div id="drag-handle" title="Drag to resize plot"></div>
</div>

<!-- ═══════════════ BOTTOM PANEL ═══════════════ -->
<div id="bottom-panel">
    <div id="table-bar">
        <span id="table-info">No data loaded</span>
        <button id="filter-toggle-btn" onclick="toggleFilters()" style="display:none;padding:2px 10px;font-size:0.8em;background:#6c757d;color:#fff;border:none;border-radius:3px;cursor:pointer">&#128269; Filters</button>
    </div>
    <div id="table-container">
        <div id="empty-state">Parse a file to see results here</div>
        <table id="result-table" style="display:none"></table>
    </div>
</div>

<script>
    let currentCsvId = null;

    function setStatus(msg, cls) {
        const el = document.getElementById('status-bar');
        el.textContent = msg;
        el.className = cls || '';
    }

    function setTableInfo(msg) {
        document.getElementById('table-info').textContent = msg;
    }

    async function parseFile() {
        const filePath = document.getElementById('path-input').value.trim();
        const fileUpload = document.getElementById('file-input').files[0];
        const regex = document.getElementById('regex-input').value.trim();
        const mode = document.querySelector('input[name="filter-mode"]:checked').value;

        if (!filePath && !fileUpload) {
            setStatus('Enter a file path or select a file to upload.', 'error');
            return;
        }

        setStatus('Submitting\u2026', 'info');
        setTableInfo('Parsing \u2026');

        // ── Step 1: submit parse request — server returns job_id immediately ──
        let jobResp;
        try {
            let resp;
            if (filePath) {
                resp = await fetch('/parse_path', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({path: filePath, regex: regex, mode: mode})
                });
            } else {
                const form = new FormData();
                form.append('file', fileUpload);
                form.append('regex', regex);
                form.append('mode', mode);
                resp = await fetch('/parse', { method: 'POST', body: form });
            }
            jobResp = await resp.json();
        } catch (e) {
            setStatus('Network error: ' + e, 'error');
            setTableInfo('Error');
            return;
        }

        // If server returned synchronously (shouldn't happen now, but be safe)
        if (jobResp.success) {
            _onParseResult(jobResp, filePath, fileUpload, Date.now());
            return;
        }

        if (!jobResp.job_id) {
            setStatus('Error: ' + (jobResp.error || 'Unknown error'), 'error');
            setTableInfo('Error');
            return;
        }

        // ── Step 2: poll /parse_status?job=<id> until done ──────────────────
        const jobId = jobResp.job_id;
        const t0 = Date.now();
        const ticker = setInterval(function() {
            const secs = ((Date.now() - t0) / 1000).toFixed(1);
            setStatus('Parsing \u2026 ' + secs + 's', 'info');
        }, 500);

        while (true) {
            await new Promise(r => setTimeout(r, 1000));  // poll every 1s
            let statusResp;
            try {
                const r = await fetch('/parse_status?job=' + jobId);
                statusResp = await r.json();
            } catch (e) {
                clearInterval(ticker);
                setStatus('Network error while polling: ' + e, 'error');
                setTableInfo('Error');
                return;
            }

            if (statusResp.state === 'pending' || statusResp.state === 'running') {
                continue;  // still working
            }

            clearInterval(ticker);

            if (!statusResp.success) {
                setStatus('Error: ' + (statusResp.error || 'Parse failed'), 'error');
                setTableInfo('Parse failed');
                return;
            }

            _onParseResult(statusResp, filePath, fileUpload, t0);
            return;
        }
    }

    function _onParseResult(result, filePath, fileUpload, t0) {
        currentCsvId = result.csv_id;
        const total = result.total_rows;
        const fname = filePath || (fileUpload ? fileUpload.name : '');
        const tSecs = ((Date.now() - t0) / 1000).toFixed(1);

        setStatus('Parsed ' + total.toLocaleString() + ' rows \u2022 ' + result.headers.length + ' columns \u2022 ' + tSecs + 's');
        setTableInfo('Loading\u2026 (0 / ' + total.toLocaleString() + ' rows) \u00b7 ' + result.headers.length + ' columns \u00b7 ' + fname);

        renderTable(result.headers, result.rows);
        loadMoreRows(result.csv_id, result.headers, result.rows.length, total, result.headers.length, fname);
        document.getElementById('download-btn').style.display = 'inline-block';

        populatePlotSelectors(result.headers);
        document.getElementById('plot-panel').style.display = 'flex';
        setTimeout(drawPlot, 200);
    }

    function renderTable(headers, rows) {
        const table = document.getElementById('result-table');
        const empty = document.getElementById('empty-state');
        empty.style.display = 'none';
        table.style.display = '';

        // Header row
        let hhtml = '<thead><tr>';
        headers.forEach(function(h) { hhtml += '<th>' + h + '</th>'; });
        hhtml += '</tr>';

        // Filter input row (hidden by default)
        hhtml += '<tr id="filter-row" style="display:none">';
        headers.forEach(function(h, i) {
            hhtml += '<th><input type="text" data-colidx="' + i + '" ' +
                     'placeholder="\u26b2" ' +
                     'oninput="applyFilters()" ' +
                     'title="Filter ' + h + '\n\nSupported syntax:\n  substring   e.g.  PASS\n  /regex/     e.g.  /^DUT[12]/\n  ==value     e.g.  ==PASS\n  !=value     e.g.  !=FAIL\n  >  >=  <  <=  e.g.  >=0.001">' +
                     '</th>';
        });
        hhtml += '</tr></thead>';

        table.innerHTML = hhtml + '<tbody id="table-body"></tbody>';

        // Show filter toggle button
        document.getElementById('filter-toggle-btn').style.display = '';

        const tbody = document.getElementById('table-body');
        const frag = document.createDocumentFragment();
        rows.forEach(function(row) {
            const tr = document.createElement('tr');
            let cells = '';
            row.forEach(function(cell) { cells += '<td>' + (cell != null ? cell : '') + '</td>'; });
            tr.innerHTML = cells;
            frag.appendChild(tr);
        });
        tbody.appendChild(frag);
    }

    // ─── COLUMN FILTERS ───────────────────────────────────────────────────
    let filtersVisible = false;

    function toggleFilters() {
        filtersVisible = !filtersVisible;
        const row = document.getElementById('filter-row');
        if (row) row.style.display = filtersVisible ? '' : 'none';
        const btn = document.getElementById('filter-toggle-btn');
        btn.style.background = filtersVisible ? '#0056b3' : '#6c757d';
        if (!filtersVisible) {
            const inputs = document.querySelectorAll('#filter-row input');
            inputs.forEach(function(inp) {
                inp.value = '';
                inp.className = '';
            });
            applyFilters();
        }
    }

    /**
     * Parse a filter expression string into a test function: (cellText) => bool
     *
     * Supported syntax:
     *   /regex/[flags]   regex literal      e.g.  /^DUT[12]/i
     *   ==val  =val      exact match        e.g.  ==PASS  or  =PASS
     *   !=val  <>val     not equal          e.g.  !=FAIL
     *   >=val            numeric >=         e.g.  >=0.001
     *   >val             numeric >
     *   <=val            numeric <=
     *   <val             numeric <
     *   anything else    case-insensitive substring / regex
     *
     * Returns { fn, type } where type is 'regex'|'op'|'sub'|'invalid'
     */
    function parseFilterExpr(raw) {
        if (!raw) return null;

        // ── /regex/flags ────────────────────────────────────────────────
        const rxLit = raw.match(/^\/(.+)\/([gimsuy]*)$/);
        if (rxLit) {
            try {
                const re = new RegExp(rxLit[1], rxLit[2] || 'i');
                return { fn: function(s) { return re.test(s); }, type: 'regex' };
            } catch(e) {
                return { fn: function() { return false; }, type: 'invalid' };
            }
        }

        // ── comparison operators ─────────────────────────────────────────
        const cmpMatch = raw.match(/^(==?|!=|<>|>=?|<=?)(.*)$/);
        if (cmpMatch) {
            const op  = cmpMatch[1];
            const rhs = cmpMatch[2].trim();
            const rhsNum = parseFloat(rhs);
            const rhsIsNum = !isNaN(rhsNum) && rhs !== '';

            return {
                type: 'op',
                fn: function(cellText) {
                    const lhsNum = parseFloat(cellText);
                    // numeric comparison when both sides are numeric
                    if (rhsIsNum && !isNaN(lhsNum)) {
                        if (op === '>'  || op === '>')  return lhsNum >  rhsNum;
                        if (op === '>=' )               return lhsNum >= rhsNum;
                        if (op === '<'  )               return lhsNum <  rhsNum;
                        if (op === '<=' )               return lhsNum <= rhsNum;
                        if (op === '==' || op === '=')  return lhsNum === rhsNum;
                        if (op === '!=' || op === '<>') return lhsNum !== rhsNum;
                    }
                    // string equality / inequality for == != <>
                    if (op === '==' || op === '=')  return cellText.toLowerCase() === rhs.toLowerCase();
                    if (op === '!=' || op === '<>') return cellText.toLowerCase() !== rhs.toLowerCase();
                    // < <= > >= on non-numeric strings: lexicographic
                    if (op === '>' )  return cellText > rhs;
                    if (op === '>=')  return cellText >= rhs;
                    if (op === '<' )  return cellText < rhs;
                    if (op === '<=')  return cellText <= rhs;
                    return false;
                }
            };
        }

        // ── plain text: try as regex, fallback to substring ───────────────
        try {
            const re = new RegExp(raw, 'i');
            return { fn: function(s) { return re.test(s); }, type: 'regex' };
        } catch(e) {
            // invalid regex → plain substring
            const lower = raw.toLowerCase();
            return { fn: function(s) { return s.toLowerCase().indexOf(lower) !== -1; }, type: 'sub' };
        }
    }

    function applyFilters() {
        const inputs = document.querySelectorAll('#filter-row input');
        const filters = [];
        let activeCount = 0;

        inputs.forEach(function(inp) {
            const val = inp.value.trim();
            // Reset classes
            inp.className = '';
            if (val === '') return;

            const parsed = parseFilterExpr(val);
            activeCount++;
            if (parsed.type === 'invalid') {
                inp.classList.add('invalid');
            } else if (parsed.type === 'op') {
                inp.classList.add('op');
            } else {
                inp.classList.add('active');
            }
            filters.push({ idx: parseInt(inp.dataset.colidx), fn: parsed.fn });
        });

        const tbody = document.getElementById('table-body');
        if (!tbody) return;
        let visCount = 0;
        const rows = tbody.querySelectorAll('tr');
        rows.forEach(function(tr) {
            if (filters.length === 0) {
                tr.classList.remove('row-hidden');
                visCount++;
                return;
            }
            const cells = tr.querySelectorAll('td');
            const pass = filters.every(function(f) {
                const cellText = cells[f.idx] ? cells[f.idx].textContent : '';
                return f.fn(cellText);
            });
            tr.classList.toggle('row-hidden', !pass);
            if (pass) visCount++;
        });

        // Update table-info
        const info = document.getElementById('table-info');
        if (info) {
            const base = info.textContent.replace(/ \u2014 \d.*$/, '');
            if (activeCount > 0) {
                info.textContent = base + ' \u2014 ' + visCount.toLocaleString() +
                    ' shown (' + activeCount + ' filter' + (activeCount > 1 ? 's' : '') + ')';
            } else {
                info.textContent = base;
            }
        }
    }

    async function downloadCSV() {
        if (!currentCsvId) { setStatus('No data to download', 'error'); return; }
        window.location.href = '/download/' + currentCsvId;
    }

    function resetAll() {
        document.getElementById('file-input').value = '';
        document.getElementById('regex-input').value = '';
        document.getElementById('result-table').innerHTML = '';
        document.getElementById('result-table').style.display = 'none';
        document.getElementById('empty-state').style.display = 'flex';
        document.getElementById('download-btn').style.display = 'none';
        document.getElementById('filter-toggle-btn').style.display = 'none';
        document.getElementById('plot-panel').style.display = 'none';
        if (chartInst) { chartInst.destroy(); chartInst = null; }
        setStatus('Ready \u2014 select a file and click Parse.');
        setTableInfo('No data loaded');
        currentCsvId = null;
        currentHeaders = [];
        domFullyLoaded = false;
        filtersVisible = false;
    }

    // ─── PROGRESSIVE ROW LOADER ──────────────────────────────────────────
    async function loadMoreRows(csv_id, headers, offset, total, ncols, fname) {
        const CHUNK = 2000;
        const tbody = document.getElementById('table-body');
        while (offset < total) {
            const r = await fetch('/rows?csv_id=' + csv_id + '&offset=' + offset + '&limit=' + CHUNK);
            const d = await r.json();
            if (!d.success) break;
            const frag = document.createDocumentFragment();
            d.rows.forEach(row => {
                const tr = document.createElement('tr');
                let cells = '';
                row.forEach(cell => { cells += '<td>' + (cell != null ? cell : '') + '</td>'; });
                tr.innerHTML = cells;
                frag.appendChild(tr);
            });
            tbody.appendChild(frag);
            offset += d.rows.length;
            // Re-apply active filters to newly appended rows so .row-hidden is always current
            if (hasActiveFilters()) applyFilters();
            setTableInfo(
                total.toLocaleString() + ' rows \u00b7 ' + ncols + ' columns \u00b7 ' + fname +
                (offset < total ? ' \u2014 loaded ' + offset.toLocaleString() + '\u2026' : '')
            );
            if (!d.has_more) break;
            await new Promise(res => setTimeout(res, 0)); // yield to browser
        }
        domFullyLoaded = true;
        setTableInfo(total.toLocaleString() + ' rows \u00b7 ' + ncols + ' columns \u00b7 ' + fname);
    }

    // ─── PLOT LOGIC ───────────────────────────────────────────────────────
    let chartInst = null;
    let currentHeaders = [];
    let domFullyLoaded = false;   // true once loadMoreRows has finished
    const PALETTE = [
        '#007bff','#e83e8c','#28a745','#fd7e14','#6610f2',
        '#17a2b8','#dc3545','#20c997','#ffc107','#6f42c1'
    ];

    // Show/hide controls depending on chart type
    function onChartTypeChange() {
        const ctype = document.getElementById('chart-type').value;
        const isXOnly = (ctype === 'histogram' || ctype === 'cumproba');
        const isCumProba = (ctype === 'cumproba');
        const isHistogram = (ctype === 'histogram');

        // Y column — only needed for scatter/line
        document.getElementById('y-col').closest('label').style.display = isXOnly ? 'none' : '';
        document.getElementById('y-regex').closest('label').style.display = isXOnly ? 'none' : '';
        // Color-by — only for scatter/line
        document.getElementById('color-col').closest('label').style.display = isXOnly ? 'none' : '';
        document.getElementById('color-rx-label').style.display = isXOnly ? 'none' : '';
        // Bins — only for histogram
        document.getElementById('bins-label').style.display = isHistogram ? '' : 'none';
        // Split-by and split-regex — only for cum proba
        document.getElementById('split-label').style.display = isCumProba ? '' : 'none';
        document.getElementById('split-rx-label').style.display = isCumProba ? '' : 'none';
        // Y scale inputs — hidden for histogram (Y is count, not data) and cumproba (Y is fixed 0-1)
        const yScaleDisplay = isXOnly ? 'none' : '';
        document.getElementById('y-min-label').style.display = yScaleDisplay;
        document.getElementById('y-max-label').style.display = yScaleDisplay;
    }

    function populatePlotSelectors(headers) {
        currentHeaders = headers;
        ['x-col','y-col','color-col','split-col'].forEach(function(id) {
            const sel = document.getElementById(id);
            const prev = sel.value;
            sel.innerHTML = (id === 'color-col' || id === 'split-col') ? '<option value="">— none —</option>' : '';
            headers.forEach(function(h) {
                const o = document.createElement('option');
                o.value = h; o.textContent = h;
                sel.appendChild(o);
            });
            if (prev) sel.value = prev;
        });
        // smart defaults
        function tryDefault(id, candidates) {
            const sel = document.getElementById(id);
            for (let ci = 0; ci < candidates.length; ci++) {
                for (let i = 0; i < sel.options.length; i++) {
                    if (sel.options[i].value.toUpperCase() === candidates[ci].toUpperCase()) {
                        sel.value = sel.options[i].value; return;
                    }
                }
            }
        }
        tryDefault('x-col',    ['WL','BLK','SB','BL','LINE#']);
        tryDefault('y-col',    ['RBER','BYBER','RBER_LIMIT','Measurement']);
        tryDefault('color-col',['DUT','RESULT','PAGETYPE','Type']);
    }

    function extractNum(val, rxStr) {
        if (rxStr) {
            try {
                const m = new RegExp(rxStr).exec(String(val));
                if (m) val = m[1] !== undefined ? m[1] : m[0];
            } catch(e) {}
        }
        const n = parseFloat(String(val).replace(/[^0-9.eE+\-]/g,''));
        return isNaN(n) ? null : n;
    }

    async function drawPlot() {
        const ctype  = document.getElementById('chart-type').value;
        if (ctype === 'histogram') { await drawHistogram(); return; }
        if (ctype === 'cumproba') { await drawCumProba(); return; }
        await drawScatterLine();
    }

    // ─── DOM DATA SOURCE ──────────────────────────────────────────────────
    // Returns true when at least one column filter input has a value
    function hasActiveFilters() {
        const inputs = document.querySelectorAll('#filter-row input');
        for (let i = 0; i < inputs.length; i++) {
            if (inputs[i].value.trim() !== '') return true;
        }
        return false;
    }

    /**
     * Read user-defined axis scale limits.
     * Returns an object suitable for merging into Chart.js scale options.
     * Only sets min/max when the user has entered a value.
     */
    function getAxisScale(minId, maxId) {
        const opts = {};
        const minVal = parseFloat(document.getElementById(minId).value);
        const maxVal = parseFloat(document.getElementById(maxId).value);
        if (!isNaN(minVal)) opts.min = minVal;
        if (!isNaN(maxVal)) opts.max = maxVal;
        return opts;
    }

    /**
     * Read data from visible DOM rows (respects column filters).
     * colMap: object whose keys are logical names and values are header column names.
     *   e.g. { x: 'WL', y: 'RBER', group: 'DUT' }
     * xRx / yRx: optional extraction regexes applied after reading cell text.
     * Returns { points: [{x, y, group}], skipped, fromDom: true }
     * For X-only charts (hist/cumproba), pass colMap = { x: 'WL', group: 'DUT' } — y is ignored.
     */
    function readVisibleRowsFromDOM(colMap, xRx, yRx) {
        const tbody = document.getElementById('table-body');
        if (!tbody) return { points: [], skipped: 0, fromDom: true };

        // Resolve column indices from currentHeaders
        function hIdx(name) {
            if (!name) return -1;
            const i = currentHeaders.indexOf(name);
            return i;
        }
        const xi   = hIdx(colMap.x);
        const yi   = colMap.y ? hIdx(colMap.y) : -1;
        const gi   = colMap.group ? hIdx(colMap.group) : -1;

        if (xi < 0) return { points: [], skipped: 0, fromDom: true };

        const points = [];
        let skipped = 0;

        const rows = tbody.querySelectorAll('tr:not(.row-hidden)');
        rows.forEach(function(tr) {
            const cells = tr.querySelectorAll('td');
            const xRaw  = cells[xi]  ? cells[xi].textContent  : '';
            const yRaw  = yi >= 0 && cells[yi]  ? cells[yi].textContent  : xRaw;
            const gRaw  = gi >= 0 && cells[gi]  ? cells[gi].textContent  : null;

            const xv = extractNum(xRaw, xRx);
            const yv = yi >= 0 ? extractNum(yRaw, yRx) : xv;  // x-only: yv = xv (dummy)

            if (xv === null || (yi >= 0 && yv === null)) { skipped++; return; }

            const pt = { x: xv, y: yv };
            if (gRaw !== null) pt.group = gRaw;
            points.push(pt);
        });

        return { points: points, skipped: skipped, fromDom: true };
    }

    // Optimised version — re-evaluates all active filters per row so the result
    // is always correct regardless of DOM load order or filter timing.
    function readVisibleRowsFromDOMFast(colMap, xRx, yRx) {
        const tbody = document.getElementById('table-body');
        if (!tbody) return { points: [], skipped: 0, fromDom: true };

        function hIdx(name) {
            if (!name) return -1;
            return currentHeaders.indexOf(name);
        }
        const xi = hIdx(colMap.x);
        const yi = colMap.y ? hIdx(colMap.y) : -1;
        const gi = colMap.group ? hIdx(colMap.group) : -1;

        if (xi < 0) return { points: [], skipped: 0, fromDom: true };

        // Build active filter list once (same logic as applyFilters)
        const activeFilters = [];
        document.querySelectorAll('#filter-row input').forEach(function(inp) {
            const val = inp.value.trim();
            if (!val) return;
            const parsed = parseFilterExpr(val);
            if (parsed && parsed.type !== 'invalid') {
                activeFilters.push({ idx: parseInt(inp.dataset.colidx), fn: parsed.fn });
            }
        });

        const points = [];
        let skipped = 0;
        const trs = tbody.children;

        for (let r = 0; r < trs.length; r++) {
            const tr = trs[r];
            const cells = tr.children;

            // Apply ALL active filters — row must pass every one
            if (activeFilters.length > 0) {
                let pass = true;
                for (let f = 0; f < activeFilters.length; f++) {
                    const cellText = cells[activeFilters[f].idx] ? cells[activeFilters[f].idx].textContent : '';
                    if (!activeFilters[f].fn(cellText)) { pass = false; break; }
                }
                if (!pass) continue;
            }

            const xRaw = cells[xi]              ? cells[xi].textContent              : '';
            const yRaw = (yi >= 0 && cells[yi]) ? cells[yi].textContent              : xRaw;
            const gRaw = (gi >= 0 && cells[gi]) ? cells[gi].textContent              : null;

            const xv = extractNum(xRaw, xRx);
            const yv = (yi >= 0) ? extractNum(yRaw, yRx) : xv;

            if (xv === null || (yi >= 0 && yv === null)) { skipped++; continue; }

            const pt = { x: xv, y: yv };
            if (gRaw !== null) pt.group = gRaw;
            points.push(pt);
        }

        return { points: points, skipped: skipped, fromDom: true };
    }

    // ─── SCATTER / LINE ───────────────────────────────────────────────────
    async function drawScatterLine() {
        const xCol   = document.getElementById('x-col').value;
        const yCol    = document.getElementById('y-col').value;
        const xRx     = document.getElementById('x-regex').value.trim();
        const yRx     = document.getElementById('y-regex').value.trim();
        const colCol  = document.getElementById('color-col').value;
        const colorRx = document.getElementById('color-regex').value.trim();
        const ctype   = document.getElementById('chart-type').value;
        const xLog    = document.getElementById('x-log').checked;
        const yLog    = document.getElementById('y-log').checked;
        const status  = document.getElementById('plot-status');

        if (!currentCsvId) { status.textContent = 'Session expired \u2014 please re-parse the file.'; return; }
        status.textContent = 'Loading\u2026';

        let points, skipped, filteredNote = '';

        if (hasActiveFilters()) {
            // Filters active → read from DOM (only source that knows which rows are visible)
            if (!domFullyLoaded) {
                status.textContent = 'Warning: rows still loading \u2014 plot may be incomplete. Wait for loading to finish before filtering.';
            }
            const result = readVisibleRowsFromDOMFast({ x: xCol, y: yCol, group: colCol || null }, xRx, yRx);
            points  = result.points;
            skipped = result.skipped;
            filteredNote = ' \u2014 filtered';
        } else {
            // No active filters → fetch from server (full dataset, not limited to DOM rows)
            const params = new URLSearchParams({
                csv_id: currentCsvId,
                x_col: xCol, y_col: yCol,
                x_regex: xRx, y_regex: yRx,
                color_col: colCol,
                max_pts: '5000'
            });
            let data;
            try {
                const r = await fetch('/plot_data?' + params.toString());
                data = await r.json();
            } catch(e) { status.textContent = 'Network error: ' + e; return; }
            if (!data.success) {
                status.textContent = (data.error && data.error.indexOf('csv_id') !== -1)
                    ? 'Session expired \u2014 please re-parse the file.'
                    : 'Error: ' + data.error;
                return;
            }
            points  = data.points;
            skipped = data.skipped;
        }

        // Apply color regex to derive group label from raw group value
        function colorGroupKey(pt) {
            if (!colCol) return '(all)';
            const raw = pt.group != null ? String(pt.group) : '(blank)';
            if (!colorRx) return raw;
            try {
                const m = new RegExp(colorRx).exec(raw);
                if (!m) return '(no match)';
                return m[1] !== undefined ? m[1] : m[0];
            } catch(e) { return raw; }
        }

        // Group by color key
        const groups = {};
        points.forEach(function(pt) {
            const g = colorGroupKey(pt);
            if (!groups[g]) groups[g] = [];
            groups[g].push({ x: pt.x, y: pt.y });
        });

        const datasets = Object.keys(groups).map(function(g, i) {
            return {
                label: g,
                data: groups[g],
                backgroundColor: PALETTE[i % PALETTE.length] + '99',
                borderColor:     PALETTE[i % PALETTE.length],
                borderWidth: ctype === 'line' ? 1.5 : 0,
                pointRadius: ctype === 'line' ? 2 : 3,
                showLine: ctype === 'line'
            };
        });

        if (chartInst) chartInst.destroy();
        const ctx = document.getElementById('plot-canvas').getContext('2d');
        chartInst = new Chart(ctx, {
            type: 'scatter',
            data: { datasets: datasets },
            options: {
                animation: false,
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: datasets.length > 1, position: 'right',
                        labels: { boxWidth: 12, font: { size: 10 } } },
                    tooltip: { callbacks: {
                        label: function(ctx) {
                            return ctx.dataset.label + ': (' + ctx.parsed.x + ', ' + ctx.parsed.y + ')';
                        }
                    }}
                },
                scales: {
                    x: Object.assign({ type: xLog ? 'logarithmic' : 'linear',
                         title: { display: true, text: xCol + (xRx ? ' [' + xRx + ']' : '') + (xLog ? ' (log)' : '') } },
                         getAxisScale('x-min', 'x-max')),
                    y: Object.assign({ type: yLog ? 'logarithmic' : 'linear',
                         title: { display: true, text: yCol + (yRx ? ' [' + yRx + ']' : '') + (yLog ? ' (log)' : '') } },
                         getAxisScale('y-min', 'y-max'))
                }
            }
        });
        status.textContent = points.length.toLocaleString() + ' pts' +
            (skipped > 0 ? ', ' + skipped + ' skipped' : '') + filteredNote;
    }

    // ─── SHARED: fetch all X values (+ optional group column) ─────────────
    // Filters active → reads from visible DOM rows (respects all column filters).
    // No filters → fetches from server (full dataset).
    async function fetchXValues(xCol, xRx, splitCol) {
        const status = document.getElementById('plot-status');

        if (hasActiveFilters()) {
            // Filters active → DOM is the only source that knows visible rows
            if (!domFullyLoaded) {
                status.textContent = 'Warning: rows still loading \u2014 plot may be incomplete.';
            }
            const result = readVisibleRowsFromDOMFast(
                { x: xCol, group: splitCol || null },
                xRx, null
            );
            result.filteredNote = ' \u2014 filtered';
            return result;
        }

        const params = new URLSearchParams({
            csv_id: currentCsvId,
            x_col: xCol,
            y_col: xCol,        // dummy — server needs a valid y col; we reuse x
            x_regex: xRx,
            y_regex: xRx,
            color_col: splitCol || '',
            max_pts: '500000'   // effectively all rows
        });
        let data;
        try {
            const r = await fetch('/plot_data?' + params.toString());
            data = await r.json();
        } catch(e) {
            status.textContent = 'Network error: ' + e;
            return null;
        }
        if (!data.success) {
            if (data.error && data.error.indexOf('csv_id') !== -1) {
                status.textContent = 'Session expired \u2014 please re-parse the file.';
            } else {
                status.textContent = 'Error: ' + data.error;
            }
            return null;
        }
        data.filteredNote = '';
        return data;
    }

    // ─── BUILD HISTOGRAM BINS ─────────────────────────────────────────────
    function autoBins(n) {
        // Sturges' rule: k = ceil(log2(n) + 1), clamped 2-200
        return Math.min(200, Math.max(2, Math.ceil(Math.log2(n) + 1)));
    }

    function buildHistBins(values, nBins) {
        if (values.length === 0) return { bins: [], counts: [], width: 0 };
        const mn = Math.min.apply(null, values);
        const mx = Math.max.apply(null, values);
        const range = mx - mn || 1;
        const w = range / nBins;
        const counts = [];
        const bins   = [];
        for (let i = 0; i < nBins; i++) {
            bins.push(mn + i * w + w / 2);   // bin centre
            counts.push(0);
        }
        values.forEach(function(v) {
            let idx = Math.floor((v - mn) / w);
            if (idx >= nBins) idx = nBins - 1;
            counts[idx]++;
        });
        return { bins: bins, counts: counts, width: w };
    }

    // ─── HISTOGRAM ────────────────────────────────────────────────────────
    async function drawHistogram() {
        const xCol   = document.getElementById('x-col').value;
        const xRx    = document.getElementById('x-regex').value.trim();
        const binsEl = document.getElementById('hist-bins');
        const yLog   = document.getElementById('y-log').checked;
        const status = document.getElementById('plot-status');

        if (!currentCsvId) { status.textContent = 'Session expired \u2014 please re-parse the file.'; return; }
        status.textContent = 'Loading\u2026';

        const data = await fetchXValues(xCol, xRx, '');
        if (!data) return;

        const allX = data.points.map(function(p) { return p.x; });
        if (allX.length === 0) { status.textContent = 'No numeric values found in column ' + xCol; return; }

        // Auto-detect bins if field is blank or zero
        const userBins = parseInt(binsEl.value);
        const nBins = (userBins >= 2) ? userBins : autoBins(allX.length);
        const autoLabel = (userBins >= 2) ? '' : ' (auto)';

        const h = buildHistBins(allX, nBins);

        if (chartInst) chartInst.destroy();
        const ctx = document.getElementById('plot-canvas').getContext('2d');
        chartInst = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: h.bins.map(function(b) { return b.toFixed(4); }),
                datasets: [{
                    label: xCol,
                    data: h.counts,
                    backgroundColor: PALETTE[0] + 'bb',
                    borderColor: PALETTE[0],
                    borderWidth: 1,
                    barPercentage: 1.0,
                    categoryPercentage: 1.0
                }]
            },
            options: {
                animation: false,
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: { callbacks: {
                        title: function(items) { return 'Centre: ' + items[0].label; },
                        label: function(item) { return 'Count: ' + item.parsed.y; }
                    }}
                },
                scales: {
                    x: Object.assign({ title: { display: true, text: xCol + (xRx ? ' [' + xRx + ']' : '') },
                         ticks: { maxTicksLimit: 12, maxRotation: 45 } },
                         getAxisScale('x-min', 'x-max')),
                    y: { type: yLog ? 'logarithmic' : 'linear',
                         title: { display: true, text: 'Count' + (yLog ? ' (log)' : '') },
                         beginAtZero: !yLog }
                }
            }
        });
        status.textContent = allX.length.toLocaleString() + ' values, ' + nBins + ' bins' + autoLabel +
            (data.skipped > 0 ? ', ' + data.skipped + ' skipped' : '') + (data.filteredNote || '');
    }

    // ─── CUMULATIVE PROBABILITY PLOT ──────────────────────────────────────
    async function drawCumProba() {
        const xCol     = document.getElementById('x-col').value;
        const xRx      = document.getElementById('x-regex').value.trim();
        const splitCol = document.getElementById('split-col').value;
        const splitRx  = document.getElementById('split-regex').value.trim();
        const xLog     = document.getElementById('x-log').checked;
        const status   = document.getElementById('plot-status');

        if (!currentCsvId) { status.textContent = 'Session expired \u2014 please re-parse the file.'; return; }
        status.textContent = 'Loading\u2026';

        // Fetch points — pass splitCol so server returns .group per point
        const data = await fetchXValues(xCol, xRx, splitCol);
        if (!data) return;

        if (data.points.length === 0) { status.textContent = 'No numeric values found in column ' + xCol; return; }

        // Build group key: regex match on .group value (or raw .group if no regex)
        function groupKey(pt) {
            if (!splitCol) return '(all)';
            const raw = pt.group != null ? String(pt.group) : '(blank)';
            if (!splitRx) return raw;
            try {
                const m = new RegExp(splitRx).exec(raw);
                if (!m) return '(no match)';
                return m[1] !== undefined ? m[1] : m[0];
            } catch(e) { return raw; }
        }

        // Group points
        const groups = {};
        data.points.forEach(function(pt) {
            const g = groupKey(pt);
            if (!groups[g]) groups[g] = [];
            groups[g].push(pt.x);
        });

        // Build one CDF dataset per group
        const datasets = Object.keys(groups).sort().map(function(g, i) {
            const vals = groups[g].slice().sort(function(a, b) { return a - b; });
            const n = vals.length;
            const pts = vals.map(function(v, j) {
                return { x: v, y: (j + 1) / n };
            });
            return {
                label: g + ' (n=' + n.toLocaleString() + ')',
                data: pts,
                borderColor: PALETTE[i % PALETTE.length],
                backgroundColor: 'transparent',
                borderWidth: 1.8,
                pointRadius: n <= 2000 ? 2 : 0,
                showLine: true,
                tension: 0
            };
        });

        if (chartInst) chartInst.destroy();
        const ctx = document.getElementById('plot-canvas').getContext('2d');
        chartInst = new Chart(ctx, {
            type: 'scatter',
            data: { datasets: datasets },
            options: {
                animation: false,
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: true, position: 'right',
                        labels: { boxWidth: 12, font: { size: 10 } } },
                    tooltip: { callbacks: {
                        label: function(item) {
                            return item.dataset.label + ': x=' + item.parsed.x.toFixed(6) +
                                   ', P=' + (item.parsed.y * 100).toFixed(2) + '%';
                        }
                    }}
                },
                scales: {
                    x: Object.assign({ type: xLog ? 'logarithmic' : 'linear',
                         title: { display: true, text: xCol + (xRx ? ' [' + xRx + ']' : '') + (xLog ? ' (log)' : '') } },
                         getAxisScale('x-min', 'x-max')),
                    y: { title: { display: true, text: 'Cumulative Probability' },
                         min: 0, max: 1,
                         ticks: { callback: function(v) { return (v * 100).toFixed(0) + '%'; } } }
                }
            }
        });

        const totalPts = data.points.length;
        const nGroups  = Object.keys(groups).length;
        const splitDesc = splitCol ? (' split by ' + splitCol + (splitRx ? ' [' + splitRx + ']' : '')) : '';
        status.textContent = totalPts.toLocaleString() + ' values' + splitDesc +
            (nGroups > 1 ? ', ' + nGroups + ' groups' : '') +
            (data.skipped > 0 ? ', ' + data.skipped + ' skipped' : '') + (data.filteredNote || '');
    }

    // ─── DRAG-TO-RESIZE PLOT ─────────────────────────────────────────────
    (function() {
        const handle = document.getElementById('drag-handle');
        let dragging = false, startY = 0, startH = 0;
        handle.addEventListener('mousedown', function(e) {
            dragging = true;
            startY = e.clientY;
            startH = document.getElementById('plot-area').offsetHeight;
            document.body.style.cursor = 'ns-resize';
            e.preventDefault();
        });
        document.addEventListener('mousemove', function(e) {
            if (!dragging) return;
            const newH = Math.max(80, Math.min(600, startH + e.clientY - startY));
            document.getElementById('plot-area').style.maxHeight = newH + 'px';
            document.getElementById('plot-area').style.minHeight = newH + 'px';
            if (chartInst) chartInst.resize();
        });
        document.addEventListener('mouseup', function() {
            dragging = false;
            document.body.style.cursor = '';
        });
    })();
</script>
</body>
</html>
